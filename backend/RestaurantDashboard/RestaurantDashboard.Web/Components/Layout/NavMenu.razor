<div class="sidebar-inner">

    <!-- Brand -->
    <div class="sidebar-brand">
        <span class="sidebar-brand__icon">🍽️</span>
        <div>
            <div class="sidebar-brand__name">Restaurant</div>
            <div class="sidebar-brand__sub">POS Dashboard</div>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav">
        <span class="sidebar-nav-label">Principal</span>

        <NavLink class="sidebar-nav-item" href="/dashboard" Match="NavLinkMatch.All">
            <span class="sidebar-nav-item__icon">
                <svg viewBox="0 0 24 24">
                    <rect x="3" y="3" width="7" height="7" rx="1" />
                    <rect x="14" y="3" width="7" height="7" rx="1" />
                    <rect x="14" y="14" width="7" height="7" rx="1" />
                    <rect x="3" y="14" width="7" height="7" rx="1" />
                </svg>
            </span>
            <span class="sidebar-nav-item__label">Dashboard</span>
        </NavLink>

        <NavLink class="sidebar-nav-item" href="/orders">
            <span class="sidebar-nav-item__icon">
                <svg viewBox="0 0 24 24">
                    <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" />
                    <rect x="9" y="3" width="6" height="4" rx="1" />
                    <line x1="9" y1="12" x2="15" y2="12" />
                    <line x1="9" y1="16" x2="12" y2="16" />
                </svg>
            </span>
            <span class="sidebar-nav-item__label">Órdenes</span>
        </NavLink>

        <NavLink class="sidebar-nav-item" href="/menu">
            <span class="sidebar-nav-item__icon">
                <svg viewBox="0 0 24 24">
                    <path d="M3 11l19-9-9 19-2-8-8-2z" />
                </svg>
            </span>
            <span class="sidebar-nav-item__label">Menú</span>
        </NavLink>
    </nav>

    <!-- Bottom: user info + logout -->
    <div class="sidebar-bottom">
        <AuthorizeView>
            <Authorized>
                <div class="sidebar-user">
                    <div class="sidebar-user__avatar">
                        @(context.User.Identity?.Name?.Substring(0, 1).ToUpperInvariant() ?? "U")
                    </div>
                    <div class="sidebar-user__info">
                        <div class="sidebar-user__name">@context.User.Identity?.Name</div>
                        <div class="sidebar-user__role">
                            @(context.User.IsInRole("Admin") ? "Admin"
                              : context.User.IsInRole("Manager") ? "Manager"
                              : "Staff")
                        </div>
                    </div>
                </div>

                <form action="/Account/Logout" method="post" class="sidebar-logout-form">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="/" />
                    <button type="submit" class="sidebar-nav-item sidebar-nav-item--logout">
                        <span class="sidebar-nav-item__icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                <polyline points="16 17 21 12 16 7" />
                                <line x1="21" y1="12" x2="9" y2="12" />
                            </svg>
                        </span>
                        <span class="sidebar-nav-item__label">Cerrar Sesión</span>
                    </button>
                </form>
            </Authorized>

            <NotAuthorized>
                <NavLink class="sidebar-nav-item" href="/Account/Login">
                    <span class="sidebar-nav-item__icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                            <polyline points="10 17 15 12 10 7" />
                            <line x1="15" y1="12" x2="3" y2="12" />
                        </svg>
                    </span>
                    <span class="sidebar-nav-item__label">Iniciar Sesión</span>
                </NavLink>
            </NotAuthorized>
        </AuthorizeView>
    </div>

</div>
