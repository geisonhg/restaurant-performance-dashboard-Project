<div class="sidenav-brand">
    <span class="sidenav-logo">🍽</span>
    <span class="sidenav-name">Restaurant<span class="sidenav-pos">POS</span></span>
</div>

<nav class="sidenav">
    <div class="sidenav-section">
        <span class="sidenav-section-label">Principal</span>
        <NavLink class="sidenav-link" href="/dashboard" Match="NavLinkMatch.All">
            <svg class="sidenav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            Dashboard
        </NavLink>
        <NavLink class="sidenav-link" href="/orders">
            <svg class="sidenav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
                <rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/>
            </svg>
            Órdenes
        </NavLink>
        <NavLink class="sidenav-link" href="/menu">
            <svg class="sidenav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
                <path d="M8 12h8M12 8v8"/>
            </svg>
            Menú
        </NavLink>
        <AuthorizeView Policy="ManagerPlus">
            <NavLink class="sidenav-link" href="/expenses">
                <svg class="sidenav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="2" y="5" width="20" height="14" rx="2"/>
                    <line x1="2" y1="10" x2="22" y2="10"/>
                </svg>
                Gastos
            </NavLink>
            <NavLink class="sidenav-link" href="/staff">
                <svg class="sidenav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 014-4h4a4 4 0 014 4v2"/>
                    <path d="M16 3.13a4 4 0 010 7.75"/><path d="M21 21v-2a4 4 0 00-3-3.87"/>
                </svg>
                Personal
            </NavLink>
        </AuthorizeView>
        <AuthorizeView Policy="CanGenerateReports">
            <NavLink class="sidenav-link" href="/reports">
                <svg class="sidenav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="12" y1="18" x2="12" y2="12"/>
                    <line x1="9" y1="15" x2="15" y2="15"/>
                </svg>
                Reportes
            </NavLink>
        </AuthorizeView>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="sidenav-section sidenav-section--bottom">
                <span class="sidenav-section-label">Cuenta</span>
                <NavLink class="sidenav-link" href="/Account/Manage">
                    <svg class="sidenav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                    </svg>
                    @context.User.Identity?.Name
                </NavLink>
                <form action="/Account/Logout" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="/Account/Login" />
                    <button type="submit" class="sidenav-link sidenav-logout">
                        <svg class="sidenav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1"/>
                        </svg>
                        Cerrar Sesión
                    </button>
                </form>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="sidenav-section sidenav-section--bottom">
                <NavLink class="sidenav-link" href="/Account/Login">
                    <svg class="sidenav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/>
                    </svg>
                    Iniciar Sesión
                </NavLink>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</nav>

<style>
    .sidenav-brand {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 1.1rem 1.25rem;
        border-bottom: 1px solid #1e2433;
    }
    .sidenav-logo { font-size: 1.3rem; }
    .sidenav-name { font-size: 0.95rem; font-weight: 800; color: #f8fafc; letter-spacing: -0.02em; }
    .sidenav-pos { color: #3b82f6; margin-left: 0.2rem; }

    .sidenav { display: flex; flex-direction: column; height: calc(100vh - 56px); padding: 0.75rem 0; }
    .sidenav-section { padding: 0 0.75rem; }
    .sidenav-section--bottom { margin-top: auto; border-top: 1px solid #1e2433; padding-top: 0.75rem; }
    .sidenav-section-label {
        display: block;
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #1e3a5f;
        font-weight: 800;
        padding: 0.5rem 0.6rem 0.3rem;
    }

    .sidenav-link {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.6rem 0.75rem;
        border-radius: 8px;
        color: #475569;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: all 0.15s;
        margin-bottom: 0.1rem;
        border-left: 2px solid transparent;
        width: 100%;
    }
    .sidenav-link:hover { color: #94a3b8; background: #0f1320; }
    .sidenav-link.active { color: #e2e8f0; background: #0f1320; border-left-color: #3b82f6; }

    .sidenav-icon {
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        opacity: 0.6;
    }
    .sidenav-link.active .sidenav-icon,
    .sidenav-link:hover .sidenav-icon { opacity: 1; }

    .sidenav-logout {
        background: none;
        border: none;
        cursor: pointer;
        font-family: inherit;
        text-align: left;
    }
    .sidenav-logout:hover { color: #f87171 !important; }
</style>
