@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="app-layout @(sidebarCollapsed ? "sidebar-collapsed" : "")">

    <aside class="app-sidebar">
        <NavMenu />
    </aside>

    <div class="app-main">

        <header class="app-topbar">
            <button class="topbar-toggle" @onclick="ToggleSidebar" title="Toggle sidebar">
                <svg viewBox="0 0 24 24">
                    <line x1="3" y1="6"  x2="21" y2="6"  />
                    <line x1="3" y1="12" x2="21" y2="12" />
                    <line x1="3" y1="18" x2="21" y2="18" />
                </svg>
            </button>

            <div class="topbar-breadcrumb">@GetPageTitle()</div>

            <div class="topbar-right">
                <AuthorizeView>
                    <Authorized>
                        <div class="topbar-user">
                            <div class="topbar-avatar">
                                @(context.User.Identity?.Name?.Substring(0, 1).ToUpperInvariant() ?? "U")
                            </div>
                            <span class="topbar-username">@context.User.Identity?.Name</span>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="app-content">
            @Body
        </main>

    </div>
</div>

<div id="blazor-error-ui">
    Error inesperado. <a href="" class="reload">Recargar</a>
    <a class="dismiss">✕</a>
</div>

@code {
    private bool sidebarCollapsed = false;

    private void ToggleSidebar() => sidebarCollapsed = !sidebarCollapsed;

    private string GetPageTitle()
    {
        var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].TrimEnd('/');
        return path switch
        {
            "dashboard" => "Dashboard",
            "orders"    => "Órdenes Abiertas",
            "menu"      => "Gestión de Menú",
            _           => "Restaurant POS"
        };
    }
}
