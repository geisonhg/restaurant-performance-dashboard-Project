@page "/dashboard"
@attribute [Authorize(Policy = "ManagerPlus")]
@using MediatR
@using RestaurantDashboard.Application.Sales.Queries.GetSalesSummary
@using RestaurantDashboard.Application.Sales.Dtos
@inject IMediator Mediator
@inject IJSRuntime JS

<PageTitle>Dashboard</PageTitle>

<div class="dash">
    <div class="dash-header">
        <div>
            <h1 class="dash-title">Performance <span class="dash-accent">Overview</span></h1>
            <p class="dash-period">@fromDate.ToString("dd MMM") — @toDate.ToString("dd MMM yyyy")</p>
        </div>
        <div class="dash-controls">
            <button class="dash-preset @(preset == 7 ? "active" : "")" @onclick="() => SetPreset(7)">7D</button>
            <button class="dash-preset @(preset == 30 ? "active" : "")" @onclick="() => SetPreset(30)">30D</button>
            <button class="dash-preset @(preset == 90 ? "active" : "")" @onclick="() => SetPreset(90)">90D</button>
            <div class="dash-divider"></div>
            <input class="dash-date-input" type="date" @bind="fromDate" @bind:event="oninput" @onchange="LoadData" />
            <input class="dash-date-input" type="date" @bind="toDate" @bind:event="oninput" @onchange="LoadData" />
        </div>
    </div>

    @if (isLoading)
    {
        <div class="dash-loading">
            <div class="dash-pulse"></div>
            <div class="dash-pulse" style="animation-delay:0.15s"></div>
            <div class="dash-pulse" style="animation-delay:0.3s"></div>
        </div>
    }
    else if (summary is not null)
    {
        <div class="kpi-row">
            <div class="kpi kpi--green">
                <div class="kpi__label">Ingresos</div>
                <div class="kpi__value">€@summary.TotalRevenue.ToString("N2")</div>
                <div class="kpi__sub">Total del período</div>
                <div class="kpi__bar"></div>
            </div>
            <div class="kpi kpi--blue">
                <div class="kpi__label">Ganancia Neta</div>
                <div class="kpi__value">€@summary.NetProfit.ToString("N2")</div>
                <div class="kpi__sub">Ingresos − Gastos</div>
                <div class="kpi__bar"></div>
            </div>
            <div class="kpi kpi--red">
                <div class="kpi__label">Gastos</div>
                <div class="kpi__value">€@summary.TotalExpenses.ToString("N2")</div>
                <div class="kpi__sub">Total del período</div>
                <div class="kpi__bar"></div>
            </div>
            <div class="kpi kpi--amber">
                <div class="kpi__label">Propinas</div>
                <div class="kpi__value">€@summary.TotalTips.ToString("N2")</div>
                <div class="kpi__sub">Acumuladas</div>
                <div class="kpi__bar"></div>
            </div>
            <div class="kpi kpi--purple">
                <div class="kpi__label">Transacciones</div>
                <div class="kpi__value">@summary.TotalTransactions</div>
                <div class="kpi__sub">Órdenes cerradas</div>
                <div class="kpi__bar"></div>
            </div>
            <div class="kpi kpi--cyan">
                <div class="kpi__label">Ticket Promedio</div>
                <div class="kpi__value">€@summary.AverageOrderValue.ToString("N2")</div>
                <div class="kpi__sub">Por orden</div>
                <div class="kpi__bar"></div>
            </div>
        </div>

        <div class="dash-grid">
            @if (summary.RevenueByPaymentMethod.Any())
            {
                <div class="dash-card dash-card--wide">
                    <div class="dash-card__head">
                        <span class="dash-card__title">Ingresos por Método de Pago</span>
                    </div>
                    <div class="chart-wrap">
                        <canvas id="paymentChart"></canvas>
                    </div>
                </div>
            }

            @if (summary.TopSellingItems.Any())
            {
                <div class="dash-card">
                    <div class="dash-card__head">
                        <span class="dash-card__title">Top Productos</span>
                        <span class="dash-card__badge">por ventas</span>
                    </div>
                    <div class="rank-list">
                        @{ int rank = 1; var maxVal = summary.TopSellingItems.Values.Max(); }
                        @foreach (var item in summary.TopSellingItems.OrderByDescending(x => x.Value).Take(7))
                        {
                            var pct = maxVal > 0 ? (int)(item.Value / maxVal * 100) : 0;
                            <div class="rank-item">
                                <span class="rank-num">#@rank</span>
                                <div class="rank-info">
                                    <span class="rank-name">@item.Key</span>
                                    <div class="rank-track"><div class="rank-bar" style="width:@pct%"></div></div>
                                </div>
                                <span class="rank-val">€@item.Value.ToString("N2")</span>
                            </div>
                            rank++;
                        }
                    </div>
                </div>
            }

            @if (summary.ExpensesByCategory.Any())
            {
                <div class="dash-card">
                    <div class="dash-card__head">
                        <span class="dash-card__title">Gastos por Categoría</span>
                        <span class="dash-card__badge">€@summary.TotalExpenses.ToString("N0") total</span>
                    </div>
                    <div class="expense-list">
                        @foreach (var exp in summary.ExpensesByCategory.OrderByDescending(x => x.Value))
                        {
                            var pct = summary.TotalExpenses > 0 ? (int)(exp.Value / summary.TotalExpenses * 100) : 0;
                            <div class="expense-item">
                                <div class="expense-top">
                                    <span class="expense-cat">@exp.Key</span>
                                    <span class="expense-val">€@exp.Value.ToString("N2")</span>
                                </div>
                                <div class="expense-track"><div class="expense-fill" style="width:@pct%"></div></div>
                                <span class="expense-pct">@pct% del total</span>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (summary.TransactionsByPaymentMethod.Any())
            {
                <div class="dash-card">
                    <div class="dash-card__head">
                        <span class="dash-card__title">Desglose de Pagos</span>
                        <span class="dash-card__badge">@summary.TotalTransactions tx</span>
                    </div>
                    <table class="data-table">
                        <thead><tr><th>Método</th><th>Ingresos</th><th>Tx</th></tr></thead>
                        <tbody>
                            @foreach (var m in summary.RevenueByPaymentMethod.OrderByDescending(x => x.Value))
                            {
                                <tr>
                                    <td><span class="method-dot"></span>@m.Key</td>
                                    <td class="td-green">€@m.Value.ToString("N2")</td>
                                    <td class="td-blue">@summary.TransactionsByPaymentMethod.GetValueOrDefault(m.Key, 0)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }
    else if (errorMessage is not null)
    {
        <div class="dash-error">⚠ @errorMessage</div>
    }
    else
    {
        <div class="dash-empty">No hay datos para el período seleccionado.</div>
    }
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
    window.renderPaymentChart = function(id, labels, values) {
        const canvas = document.getElementById(id);
        if (!canvas) return;
        if (canvas._ci) canvas._ci.destroy();
        canvas._ci = new Chart(canvas, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    data: values,
                    backgroundColor: ['#3b82f6','#10b981','#f59e0b','#8b5cf6','#ef4444','#06b6d4'],
                    borderRadius: 6,
                    borderSkipped: false,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { color: '#1e2433' }, ticks: { color: '#475569', font: { size: 11 } } },
                    y: { grid: { color: '#1e2433' }, ticks: { color: '#475569', callback: v => '€' + v, font: { size: 11 } } }
                }
            }
        });
    };
</script>

<style>
    .dash { padding: 1.75rem 2rem; min-height: 100vh; background: #0b0e14; color: #e2e8f0; font-family: 'Segoe UI', system-ui, sans-serif; }
    .dash-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 1.75rem; flex-wrap: wrap; gap: 1rem; }
    .dash-title { font-size: 1.75rem; font-weight: 800; color: #f8fafc; letter-spacing: -0.03em; margin: 0; }
    .dash-accent { color: #3b82f6; }
    .dash-period { color: #475569; font-size: 0.82rem; margin-top: 0.2rem; }
    .dash-controls { display: flex; align-items: center; gap: 0.4rem; background: #131720; border: 1px solid #1e2433; border-radius: 10px; padding: 0.45rem; }
    .dash-preset { background: none; border: none; color: #475569; font-size: 0.78rem; font-weight: 700; padding: 0.35rem 0.65rem; border-radius: 6px; cursor: pointer; transition: all 0.15s; letter-spacing: 0.04em; }
    .dash-preset:hover { color: #e2e8f0; background: #1e2433; }
    .dash-preset.active { background: #1d3461; color: #60a5fa; }
    .dash-divider { width: 1px; height: 18px; background: #1e2433; margin: 0 0.2rem; }
    .dash-date-input { background: #0b0e14; border: 1px solid #1e2433; color: #64748b; padding: 0.3rem 0.5rem; border-radius: 6px; font-size: 0.78rem; }

    .kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
    .kpi { background: #131720; border: 1px solid #1e2433; border-radius: 12px; padding: 1.1rem 1.1rem 0; overflow: hidden; transition: transform 0.2s; }
    .kpi:hover { transform: translateY(-2px); }
    .kpi__label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: #475569; font-weight: 700; margin-bottom: 0.45rem; }
    .kpi__value { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1; }
    .kpi__sub { font-size: 0.72rem; color: #334155; margin-top: 0.35rem; margin-bottom: 0.9rem; }
    .kpi__bar { height: 3px; margin: 0 -1.1rem; }
    .kpi--green .kpi__value { color: #34d399; } .kpi--green .kpi__bar { background: #10b981; }
    .kpi--blue  .kpi__value { color: #60a5fa; } .kpi--blue  .kpi__bar { background: #3b82f6; }
    .kpi--red   .kpi__value { color: #f87171; } .kpi--red   .kpi__bar { background: #ef4444; }
    .kpi--amber .kpi__value { color: #fbbf24; } .kpi--amber .kpi__bar { background: #f59e0b; }
    .kpi--purple .kpi__value { color: #a78bfa; } .kpi--purple .kpi__bar { background: #8b5cf6; }
    .kpi--cyan  .kpi__value { color: #22d3ee; } .kpi--cyan  .kpi__bar { background: #06b6d4; }

    .dash-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.25rem; }
    .dash-card { background: #131720; border: 1px solid #1e2433; border-radius: 12px; padding: 1.25rem; }
    .dash-card--wide { grid-column: 1 / -1; }
    .dash-card__head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
    .dash-card__title { font-size: 0.72rem; font-weight: 700; color: #475569; text-transform: uppercase; letter-spacing: 0.08em; }
    .dash-card__badge { font-size: 0.7rem; background: #0f1320; color: #334155; padding: 0.2rem 0.6rem; border-radius: 20px; border: 1px solid #1e2433; }
    .chart-wrap { height: 200px; position: relative; }

    .rank-list { display: flex; flex-direction: column; gap: 0.8rem; }
    .rank-item { display: flex; align-items: center; gap: 0.7rem; }
    .rank-num { font-size: 0.68rem; color: #1e2d4a; font-weight: 800; width: 18px; text-align: right; flex-shrink: 0; }
    .rank-info { flex: 1; min-width: 0; }
    .rank-name { font-size: 0.83rem; color: #94a3b8; display: block; margin-bottom: 0.28rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .rank-track { height: 4px; background: #1e2433; border-radius: 2px; overflow: hidden; }
    .rank-bar { height: 100%; background: linear-gradient(90deg, #1d4ed8, #06b6d4); border-radius: 2px; transition: width 0.6s ease; }
    .rank-val { font-size: 0.8rem; color: #34d399; font-weight: 700; flex-shrink: 0; }

    .expense-list { display: flex; flex-direction: column; gap: 0.9rem; }
    .expense-top { display: flex; justify-content: space-between; margin-bottom: 0.3rem; }
    .expense-cat { font-size: 0.83rem; color: #94a3b8; }
    .expense-val { font-size: 0.83rem; color: #f87171; font-weight: 700; }
    .expense-track { height: 4px; background: #1e2433; border-radius: 3px; overflow: hidden; margin-bottom: 0.2rem; }
    .expense-fill { height: 100%; background: linear-gradient(90deg, #991b1b, #f97316); border-radius: 3px; }
    .expense-pct { font-size: 0.68rem; color: #334155; }

    .data-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .data-table th { text-align: left; padding: 0.45rem 0.5rem; color: #334155; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1px solid #1e2433; }
    .data-table td { padding: 0.6rem 0.5rem; border-bottom: 1px solid #0f1320; color: #64748b; }
    .data-table tr:last-child td { border-bottom: none; }
    .td-green { color: #34d399; font-weight: 700; }
    .td-blue { color: #60a5fa; font-weight: 600; }
    .method-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #3b82f6; margin-right: 0.5rem; vertical-align: middle; }

    .dash-loading { display: flex; align-items: center; gap: 0.5rem; padding: 4rem; justify-content: center; }
    .dash-pulse { width: 10px; height: 10px; border-radius: 50%; background: #3b82f6; animation: pulse 1s ease-in-out infinite; }
    @@keyframes pulse { 0%,100% { opacity: 0.3; transform: scale(0.8); } 50% { opacity: 1; transform: scale(1.2); } }
    .dash-error { background: #1a0a0a; border: 1px solid #7f1d1d; color: #fca5a5; padding: 1rem 1.5rem; border-radius: 10px; }
    .dash-empty { text-align: center; padding: 4rem; color: #334155; }
</style>

@code {
    private SalesSummaryDto? summary;
    private bool isLoading = true;
    private string? errorMessage;
    private int preset = 30;
    private DateOnly fromDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-30));
    private DateOnly toDate = DateOnly.FromDateTime(DateTime.Today);

    protected override async Task OnInitializedAsync() => await LoadData();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && summary is not null && summary.RevenueByPaymentMethod.Any())
            await RenderChart();
    }

    private async Task SetPreset(int days)
    {
        preset = days;
        fromDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-days));
        toDate = DateOnly.FromDateTime(DateTime.Today);
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();
        try { summary = await Mediator.Send(new GetSalesSummaryQuery { From = fromDate, To = toDate }); }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task RenderChart()
    {
        if (summary is null) return;
        try
        {
            var labels = summary.RevenueByPaymentMethod.Keys.ToArray();
            var values = summary.RevenueByPaymentMethod.Values.Select(v => (double)v).ToArray();
            await JS.InvokeVoidAsync("renderPaymentChart", "paymentChart", labels, values);
        }
        catch { }
    }
}
