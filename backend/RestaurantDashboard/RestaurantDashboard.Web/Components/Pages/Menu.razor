@page "/menu"
@attribute [Authorize(Policy = "ManagerPlus")]
@using MediatR
@using RestaurantDashboard.Application.MenuItems.Queries.GetMenuItems
@using RestaurantDashboard.Application.MenuItems.Commands.CreateMenuItem
@using RestaurantDashboard.Application.MenuItems.Commands.UpdateMenuItem
@using RestaurantDashboard.Application.MenuItems.Dtos
@inject IMediator Mediator

<PageTitle>Menú</PageTitle>

<div class="mn-page">
    <div class="mn-header">
        <div>
            <h1 class="mn-title">Menú</h1>
            <p class="mn-subtitle">Gestión de productos y categorías</p>
        </div>
        <button class="mn-btn mn-btn--add" @onclick="OpenCreateForm">+ Nuevo Producto</button>
    </div>

    <div class="mn-filters">
        <input class="mn-search" type="text" placeholder="🔍 Buscar producto..." @bind="searchTerm" @bind:event="oninput" />
        <select class="mn-select" @bind="selectedCategory">
            <option value="">Todas las categorías</option>
            @foreach (var cat in categories)
            {
                <option value="@cat">@cat</option>
            }
        </select>
        <label class="mn-toggle">
            <input type="checkbox" @bind="showOnlyAvailable" />
            Solo disponibles
        </label>
    </div>

    @if (isLoading)
    {
        <div class="mn-loading"><div class="mn-spinner"></div><span>Cargando menú...</span></div>
    }
    else
    {
        <div class="mn-grid">
            @foreach (var item in FilteredItems)
            {
                <div class="mn-item @(!item.IsAvailable ? "mn-item--unavailable" : "")">
                    <div class="mn-item__top">
                        <span class="mn-item__category">@item.Category</span>
                        <span class="mn-item__badge @(item.IsAvailable ? "mn-item__badge--available" : "mn-item__badge--unavailable")">
                            @(item.IsAvailable ? "Disponible" : "No disponible")
                        </span>
                    </div>
                    <div class="mn-item__name">@item.Name</div>
                    <div class="mn-item__price">@item.BasePrice.ToString("C")</div>
                    <button class="mn-btn mn-btn--edit" @onclick="() => OpenEditForm(item)">✏️ Editar</button>
                </div>
            }
        </div>

        @if (!FilteredItems.Any())
        {
            <div class="mn-empty">No se encontraron productos con los filtros aplicados.</div>
        }
    }

    @if (showForm)
    {
        <div class="mn-modal-backdrop" @onclick="CloseForm">
            <div class="mn-modal" @onclick:stopPropagation>
                <h2 class="mn-modal__title">@(isEditing ? "Editar Producto" : "Nuevo Producto")</h2>

                <div class="mn-form">
                    <label>Nombre</label>
                    <input class="mn-input" @bind="formName" placeholder="Ej: Hamburguesa Clásica" />

                    <label>Categoría</label>
                    <input class="mn-input" @bind="formCategory" placeholder="Ej: Entradas, Platos, Postres" />

                    <label>Precio Base</label>
                    <input class="mn-input" type="number" step="0.01" @bind="formPrice" />

                    <label class="mn-checkbox-label">
                        <input type="checkbox" @bind="formIsAvailable" /> Disponible
                    </label>

                    @if (formError is not null)
                    {
                        <div class="mn-form-error">@formError</div>
                    }

                    <div class="mn-form-actions">
                        <button class="mn-btn mn-btn--cancel" @onclick="CloseForm">Cancelar</button>
                        <button class="mn-btn mn-btn--save" @onclick="SaveItem" disabled="@isSaving">
                            @(isSaving ? "Guardando..." : "Guardar")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .mn-page { padding: 2rem; background: #0f1117; min-height: 100vh; color: #e2e8f0; font-family: 'Segoe UI', sans-serif; }
    .mn-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .mn-title { font-size: 2rem; font-weight: 700; color: #f8fafc; margin: 0; }
    .mn-subtitle { color: #64748b; margin: 0.25rem 0 0; }
    .mn-filters { display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; align-items: center; }
    .mn-search, .mn-select { background: #1e2433; border: 1px solid #2d3748; color: #e2e8f0; padding: 0.6rem 1rem; border-radius: 8px; font-size: 0.9rem; }
    .mn-search { flex: 1; min-width: 200px; }
    .mn-toggle { display: flex; align-items: center; gap: 0.5rem; color: #94a3b8; font-size: 0.9rem; cursor: pointer; }
    .mn-btn { padding: 0.6rem 1.25rem; border-radius: 8px; border: none; cursor: pointer; font-weight: 600; font-size: 0.9rem; transition: all 0.2s; }
    .mn-btn--add { background: #3b82f6; color: white; }
    .mn-btn--add:hover { background: #2563eb; }
    .mn-btn--edit { background: #1e2433; border: 1px solid #2d3748; color: #94a3b8; font-size: 0.8rem; padding: 0.4rem 0.9rem; width: 100%; margin-top: 0.75rem; }
    .mn-btn--edit:hover { border-color: #3b82f6; color: #3b82f6; }
    .mn-btn--save { background: #10b981; color: white; }
    .mn-btn--save:hover:not(:disabled) { background: #059669; }
    .mn-btn--cancel { background: #1e2433; border: 1px solid #2d3748; color: #94a3b8; }
    .mn-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .mn-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; }
    .mn-item { background: #1e2433; border: 1px solid #2d3748; border-radius: 14px; padding: 1.25rem; transition: all 0.2s; }
    .mn-item:hover { border-color: #3b82f6; }
    .mn-item--unavailable { opacity: 0.5; }
    .mn-item__top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
    .mn-item__category { font-size: 0.75rem; color: #64748b; background: #0f1117; padding: 0.2rem 0.6rem; border-radius: 20px; }
    .mn-item__badge { font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 20px; font-weight: 600; }
    .mn-item__badge--available { background: #064e3b; color: #10b981; }
    .mn-item__badge--unavailable { background: #2d1515; color: #ef4444; }
    .mn-item__name { font-size: 1.05rem; font-weight: 600; color: #f8fafc; margin-bottom: 0.5rem; }
    .mn-item__price { font-size: 1.4rem; font-weight: 700; color: #10b981; }
    .mn-loading { display: flex; align-items: center; gap: 1rem; padding: 3rem; color: #64748b; }
    .mn-spinner { width: 32px; height: 32px; border: 3px solid #2d3748; border-top-color: #3b82f6; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .mn-empty { text-align: center; padding: 3rem; color: #64748b; }
    .mn-modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 100; }
    .mn-modal { background: #1e2433; border: 1px solid #2d3748; border-radius: 16px; padding: 2rem; width: 100%; max-width: 440px; }
    .mn-modal__title { font-size: 1.3rem; font-weight: 700; color: #f8fafc; margin: 0 0 1.5rem; }
    .mn-form { display: flex; flex-direction: column; gap: 0.75rem; }
    .mn-form label { font-size: 0.85rem; color: #94a3b8; }
    .mn-input { background: #0f1117; border: 1px solid #2d3748; color: #e2e8f0; padding: 0.65rem 0.9rem; border-radius: 8px; font-size: 0.95rem; }
    .mn-input:focus { outline: none; border-color: #3b82f6; }
    .mn-checkbox-label { display: flex; align-items: center; gap: 0.5rem; color: #94a3b8; cursor: pointer; }
    .mn-form-error { background: #2d1515; border: 1px solid #ef4444; color: #fca5a5; padding: 0.75rem; border-radius: 8px; font-size: 0.85rem; }
    .mn-form-actions { display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 0.5rem; }
</style>

@code {
    private IReadOnlyList<MenuItemDto>? items;
    private bool isLoading = true;
    private string searchTerm = "";
    private string selectedCategory = "";
    private bool showOnlyAvailable = false;

    // Form state
    private bool showForm = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private Guid? editingId;
    private string formName = "";
    private string formCategory = "";
    private decimal formPrice = 0;
    private bool formIsAvailable = true;
    private string? formError;

    private IEnumerable<string> categories => items == null
        ? Enumerable.Empty<string>()
        : items.Select(i => i.Category).Distinct().OrderBy(c => c);

    private IEnumerable<MenuItemDto> FilteredItems => (items ?? new List<MenuItemDto>())
        .Where(i => string.IsNullOrEmpty(searchTerm) || i.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(i => string.IsNullOrEmpty(selectedCategory) || i.Category == selectedCategory)
        .Where(i => !showOnlyAvailable || i.IsAvailable);

    protected override async Task OnInitializedAsync()
    {
        try { items = await Mediator.Send(new GetMenuItemsQuery()); }
        catch { }
        finally { isLoading = false; }
    }

    private void OpenCreateForm()
    {
        isEditing = false; editingId = null;
        formName = ""; formCategory = ""; formPrice = 0; formIsAvailable = true; formError = null;
        showForm = true;
    }

    private void OpenEditForm(MenuItemDto item)
    {
        isEditing = true; editingId = item.Id;
        formName = item.Name; formCategory = item.Category;
        formPrice = item.BasePrice; formIsAvailable = item.IsAvailable; formError = null;
        showForm = true;
    }

    private void CloseForm() { showForm = false; formError = null; }

    private async Task SaveItem()
    {
        if (string.IsNullOrWhiteSpace(formName)) { formError = "El nombre es requerido."; return; }
        if (string.IsNullOrWhiteSpace(formCategory)) { formError = "La categoría es requerida."; return; }
        if (formPrice <= 0) { formError = "El precio debe ser mayor a 0."; return; }

        isSaving = true;
        formError = null;
        try
        {
            if (isEditing && editingId.HasValue)
                await Mediator.Send(new UpdateMenuItemCommand { MenuItemId = editingId.Value, Name = formName, Category = formCategory, BasePrice = formPrice, IsAvailable = formIsAvailable });
            else
                await Mediator.Send(new CreateMenuItemCommand { Name = formName, Category = formCategory, BasePrice = formPrice });

            items = await Mediator.Send(new GetMenuItemsQuery());
            CloseForm();
        }
        catch (Exception ex) { formError = $"Error: {ex.Message}"; }
        finally { isSaving = false; }
    }
}
