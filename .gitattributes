# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Force LF for source files
*.cs    text eol=lf
*.razor text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
*.md    text eol=lf
*.csproj text eol=lf
*.sln   text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.pdf   binary
*.zip   binary
